# Copy this file to .env.prod and fill with strong secrets before deployment.

# Runtime
ASPNETCORE_ENVIRONMENT=Production
ECOMMERCE_DOMAIN=ecommerce.berkansozer.com

# Production database
DATABASE_PROD_PORT=5434
DATABASE_PROD_NAME=ecommerce_prod
DATABASE_PROD_USER=ecommerce_prod_user
DATABASE_PROD_PASSWORD=change_me_strong_password

# API security
JWT_SECRET_KEY=replace_with_min_32_char_secret
JWT_ISSUER=EcommerceAPI
JWT_AUDIENCE=EcommerceAPI
JWT_EXPIRATION_MINUTES=60
ALLOWED_ORIGINS=https://ecommerce.berkansozer.com
ALLOWED_HOSTS=ecommerce.berkansozer.com

# Cache and message broker
REDIS_CONNECTION_STRING=redis:6379
SIGNALR_REDIS_BACKPLANE_ENABLED=false
SIGNALR_CHANNEL_PREFIX=ecommerce-prod
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=ecommerce_rabbit
RABBITMQ_PASSWORD=change_me_rabbitmq_password
RABBITMQ_VHOST=/ecommerce
RABBITMQ_PREFETCH_COUNT=32

# Search/logging (optional for lean demo)
ELASTICSEARCH_URL=http://elasticsearch:9200
PRODUCT_INDEX_SYNC_FORCE_FAIL=false
OTEL_ENABLED=false
OTEL_SERVICE_NAME=EcommerceAPI.API
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Payment provider
IYZICO_API_KEY=sandbox-
IYZICO_SECRET_KEY=sandbox-
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Encryption / hashing
ENCRYPTION_KEY=replace_with_exactly_32_char_key
HASH_PEPPER=replace_with_random_pepper_value

# Social login
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Email notifications
EMAIL_PROVIDER=Resend
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS=noreply@ecommerce.berkansozer.com
EMAIL_FROM_NAME=E-Ticaret
EMAIL_BASE_URL=https://ecommerce.berkansozer.com

# Cloudflare R2 object storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ecommerce-images
R2_PUBLIC_BASE_URL=https://img.ecommerce.berkansozer.com
R2_PRESIGNED_URL_EXPIRY_SECONDS=300

# Frontend build-time values
FRONTEND_VITE_API_URL=/api/v1
FRONTEND_VITE_SITE_URL=https://ecommerce.berkansozer.com
FRONTEND_VITE_APPLE_REDIRECT_URI=https://ecommerce.berkansozer.com/login
FRONTEND_VITE_GRAFANA_ADMIN_URL=
FRONTEND_VITE_ENABLE_CHEAT_CODES=false
