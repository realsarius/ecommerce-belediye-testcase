{
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/ecommerce",
    "Username": "ecommerce_rabbit",
    "Password": "rabbit_password",
    "PrefetchCount": 32
  },
  "OpenTelemetry": {
    "Enabled": false,
    "ServiceName": "EcommerceAPI.API",
    "OtlpEndpoint": ""
  },
  "Redis": {
    "ConnectionString": null
  },
  "Cors": {
    "AllowedOrigins": [
      "http://ecommerce.berkansozer.com",
      "https://ecommerce.berkansozer.com",
      "http://10.2.2.103:3000"
    ]
  },
  "SignalR": {
    "RedisBackplaneEnabled": false,
    "ChannelPrefix": "ecommerce"
  },
  "EmailNotifications": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "EnableSsl": true,
    "FromAddress": "",
    "FromName": "E-Ticaret"
  },
  "PaymentSettings": {
    "ActiveProviders": [
      "Iyzico"
    ],
    "DefaultProvider": "Iyzico",
    "EnableMultiProviderSelection": true,
    "EnableTokenizedCardSave": true,
    "AllowLegacyEncryptedSavedCardPayments": true,
    "Force3DSecure": false,
    "Force3DSecureAbove": 5000.0,
    "PublicApiBaseUrl": "http://localhost:5294"
  },
  "ReturnAttachments": {
    "RootPath": "private-uploads/returns",
    "MaxFiles": 5,
    "MaxFileSizeBytes": 5242880,
    "SignedUrlLifetimeMinutes": 15,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp",
      "image/heic"
    ]
  },
  "RefundRetry": {
    "Enabled": true,
    "MaxAttempts": 3,
    "InitialDelayMinutes": 5,
    "BackoffMultiplier": 2
  },
  "FrontendFeatures": {
    "EnableCheckoutLegalConsents": true,
    "EnableCheckoutInvoiceInfo": true,
    "EnableShipmentTimeline": true,
    "EnableReturnAttachments": true
  },
  "Cache": {
    "ProductListTTLMinutes": 5,
    "DefaultTTLMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "localhost;127.0.0.1;10.2.2.103;ecommerce.berkansozer.com"
}
