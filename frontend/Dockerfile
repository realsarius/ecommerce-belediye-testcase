FROM node:22-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL
ARG VITE_SITE_URL
ENV VITE_SITE_URL=$VITE_SITE_URL
ARG VITE_GOOGLE_CLIENT_ID
ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
ARG VITE_APPLE_CLIENT_ID
ENV VITE_APPLE_CLIENT_ID=$VITE_APPLE_CLIENT_ID
ARG VITE_APPLE_REDIRECT_URI
ENV VITE_APPLE_REDIRECT_URI=$VITE_APPLE_REDIRECT_URI
ARG VITE_GRAFANA_ADMIN_URL
ENV VITE_GRAFANA_ADMIN_URL=$VITE_GRAFANA_ADMIN_URL
ARG VITE_ENABLE_CHEAT_CODES
ENV VITE_ENABLE_CHEAT_CODES=$VITE_ENABLE_CHEAT_CODES

RUN npm run build

FROM nginx:alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf

COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
